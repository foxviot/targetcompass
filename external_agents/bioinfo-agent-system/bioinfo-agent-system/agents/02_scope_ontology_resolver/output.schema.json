{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScopeOntologyResolverOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema_version",
    "created_at",
    "provenance",
    "warnings",
    "blocking_failures",
    "claim_ceiling",
    "normalized_question_ref",
    "disease_candidates",
    "tissue_candidates",
    "species_scope",
    "population_scope",
    "cell_type_candidates",
    "molecular_entity_types",
    "biological_program_terms",
    "gene_set_candidates",
    "synonyms",
    "excluded_expansions",
    "search_query_terms",
    "ambiguity_report",
    "recommended_scope"
  ],
  "properties": {
    "agent_id": {"type": "string", "const": "02_scope_ontology_resolver"},
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "enum": ["mock", "paper", "dataset", "manual"]}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "blocking_failures": {"type": "array", "items": {"type": "string"}},
    "claim_ceiling": {"type": "object", "additionalProperties": false, "required": ["max_allowed_claim", "reason"], "properties": {"max_allowed_claim": {"type": "string", "enum": ["descriptive", "association", "correlation", "co_expression", "cell_state_marker", "candidate_biomarker", "mechanistic_hypothesis", "causal_support", "therapeutic_target_hypothesis", "experimentally_validated_target"]}, "reason": {"type": "string", "minLength": 1}}},
    "normalized_question_ref": {"type": "string", "minLength": 1},
    "disease_candidates": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "tissue_candidates": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "species_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "population_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "cell_type_candidates": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "molecular_entity_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "biological_program_terms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "gene_set_candidates": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "synonyms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "excluded_expansions": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "search_query_terms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "ambiguity_report": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "recommended_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disease", "tissue", "species", "molecular_constraint"],
      "properties": {
        "disease": {"type": "string", "minLength": 1},
        "tissue": {"type": "string", "minLength": 1},
        "species": {"type": "string", "minLength": 1},
        "molecular_constraint": {"type": "string", "minLength": 1}
      }
    }
  }
}
