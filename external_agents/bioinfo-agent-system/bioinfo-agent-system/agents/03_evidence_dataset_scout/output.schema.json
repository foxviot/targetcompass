{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceDatasetScoutOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema_version",
    "created_at",
    "provenance",
    "warnings",
    "blocking_failures",
    "claim_ceiling",
    "normalized_question_ref",
    "analogous_studies",
    "dataset_candidates",
    "answerable_parts",
    "unanswerable_parts",
    "no_suitable_dataset",
    "recommended_dataset_ids"
  ],
  "properties": {
    "agent_id": {"type": "string", "const": "03_evidence_dataset_scout"},
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "enum": ["mock", "paper", "dataset", "manual"]}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "blocking_failures": {"type": "array", "items": {"type": "string"}},
    "claim_ceiling": {"type": "object", "additionalProperties": false, "required": ["max_allowed_claim", "reason"], "properties": {"max_allowed_claim": {"type": "string", "enum": ["descriptive", "association", "correlation", "co_expression", "cell_state_marker", "candidate_biomarker", "mechanistic_hypothesis", "causal_support", "therapeutic_target_hypothesis", "experimentally_validated_target"]}, "reason": {"type": "string", "minLength": 1}}},
    "normalized_question_ref": {"type": "string", "minLength": 1},
    "analogous_studies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["study_id", "source_type", "source_identifier", "relevance", "supports", "does_not_support", "provenance"],
        "properties": {
          "study_id": {"type": "string", "minLength": 1},
          "source_type": {"type": "string", "const": "mock"},
          "source_identifier": {"type": "string", "minLength": 1},
          "relevance": {"type": "string", "minLength": 1},
          "supports": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "does_not_support": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "provenance": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "const": "mock"}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}
        }
      }
    },
    "dataset_candidates": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dataset_id",
          "repository",
          "accession",
          "organism",
          "tissue",
          "assay_type",
          "sample_size",
          "metadata_fields",
          "data_availability",
          "supports",
          "does_not_support",
          "feasibility_score",
          "recommendation",
          "provenance"
        ],
        "properties": {
          "dataset_id": {"type": "string", "minLength": 1},
          "repository": {"type": "string", "minLength": 1},
          "accession": {"type": "string", "minLength": 1},
          "organism": {"type": "string", "minLength": 1},
          "tissue": {"type": "string", "minLength": 1},
          "assay_type": {"type": "string", "minLength": 1},
          "sample_size": {"type": "integer", "minimum": 0},
          "metadata_fields": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "data_availability": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "supports": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "does_not_support": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "feasibility_score": {"type": "integer", "minimum": 0, "maximum": 100},
          "recommendation": {"type": "string", "enum": ["primary", "fallback", "reject"]},
          "provenance": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "const": "mock"}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}
        }
      }
    },
    "answerable_parts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "unanswerable_parts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "no_suitable_dataset": {"type": "boolean"},
    "recommended_dataset_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
