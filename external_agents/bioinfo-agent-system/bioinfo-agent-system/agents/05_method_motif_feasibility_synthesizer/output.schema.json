{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MethodMotifFeasibilitySynthesizerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema_version",
    "created_at",
    "provenance",
    "warnings",
    "blocking_failures",
    "claim_ceiling",
    "method_motifs",
    "not_recommended_methods",
    "method_quality_flags",
    "local_method_contracts",
    "ready_contracts",
    "blocked_contracts",
    "missing_contracts"
  ],
  "properties": {
    "agent_id": {"type": "string", "const": "05_method_motif_feasibility_synthesizer"},
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "enum": ["mock", "paper", "dataset", "manual"]}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "blocking_failures": {"type": "array", "items": {"type": "string"}},
    "claim_ceiling": {"type": "object", "additionalProperties": false, "required": ["max_allowed_claim", "reason"], "properties": {"max_allowed_claim": {"type": "string", "enum": ["descriptive", "association", "correlation", "co_expression", "cell_state_marker", "candidate_biomarker", "mechanistic_hypothesis", "causal_support", "therapeutic_target_hypothesis", "experimentally_validated_target"]}, "reason": {"type": "string", "minLength": 1}}},
    "method_motifs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["motif_id", "applicable_questions", "required_inputs", "recommended_steps", "optional_steps", "not_applicable_when", "common_failure_modes", "evidence_type_produced", "transferability_assessment", "feasibility_assessment"],
        "properties": {
          "motif_id": {"type": "string", "minLength": 1},
          "applicable_questions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "required_inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "recommended_steps": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "optional_steps": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "not_applicable_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "common_failure_modes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "evidence_type_produced": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "transferability_assessment": {"type": "string", "minLength": 1},
          "feasibility_assessment": {"type": "string", "minLength": 1}
        }
      }
    },
    "not_recommended_methods": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "method_quality_flags": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "local_method_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contract_id", "purpose", "status", "required_inputs", "notes"],
        "properties": {
          "contract_id": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["ready", "blocked", "missing"]},
          "required_inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "notes": {"type": "string", "minLength": 1}
        }
      }
    },
    "ready_contracts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "blocked_contracts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "missing_contracts": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
