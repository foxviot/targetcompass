{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchPlanCompilerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema_version",
    "created_at",
    "provenance",
    "warnings",
    "blocking_failures",
    "claim_ceiling",
    "plan_id",
    "normalized_research_question",
    "answerable_scope",
    "unanswerable_scope",
    "selected_datasets",
    "selected_method_contracts",
    "evidence_dag",
    "task_dag",
    "fallback_paths",
    "stop_conditions",
    "claim_boundaries",
    "report_outline",
    "codex_task_packets"
  ],
  "properties": {
    "agent_id": {"type": "string", "const": "06_research_plan_compiler"},
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_type", "source_id", "note"], "properties": {"source_type": {"type": "string", "enum": ["mock", "paper", "dataset", "manual"]}, "source_id": {"type": "string", "minLength": 1}, "note": {"type": "string", "minLength": 1}}}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "blocking_failures": {"type": "array", "items": {"type": "string"}},
    "claim_ceiling": {"type": "object", "additionalProperties": false, "required": ["max_allowed_claim", "reason"], "properties": {"max_allowed_claim": {"type": "string", "enum": ["descriptive", "association", "correlation", "co_expression", "cell_state_marker", "candidate_biomarker", "mechanistic_hypothesis", "causal_support", "therapeutic_target_hypothesis", "experimentally_validated_target"]}, "reason": {"type": "string", "minLength": 1}}},
    "plan_id": {"type": "string", "minLength": 1},
    "normalized_research_question": {"type": "string", "minLength": 1},
    "answerable_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "unanswerable_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "selected_datasets": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "selected_method_contracts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_dag": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["edge_id", "from", "to", "rationale"],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "from": {"type": "string", "minLength": 1},
          "to": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "task_dag": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "name", "purpose", "input_artifacts", "output_artifacts", "dependencies", "method_contract_id", "acceptance_criteria", "failure_condition"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "input_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "output_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "method_contract_id": {"type": "string", "minLength": 1},
          "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "failure_condition": {"type": "string", "minLength": 1}
        }
      }
    },
    "fallback_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "claim_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_claims", "forbidden_claims", "caveats"],
      "properties": {
        "allowed_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "forbidden_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "caveats": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "report_outline": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "codex_task_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "name", "purpose", "input_artifacts", "output_artifacts", "dependencies", "method_contract_id", "acceptance_criteria", "failure_condition", "notes"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "input_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "output_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "dependencies": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "method_contract_id": {"type": "string", "minLength": 1},
          "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "failure_condition": {"type": "string", "minLength": 1},
          "notes": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
