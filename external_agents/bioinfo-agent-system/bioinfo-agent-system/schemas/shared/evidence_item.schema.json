{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "item_type",
    "label",
    "supports",
    "does_not_support",
    "provenance"
  ],
  "properties": {
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "item_type": {
      "type": "string",
      "enum": ["study", "dataset", "method", "claim"]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "supports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "does_not_support": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "note"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["mock", "paper", "dataset", "manual"]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
