{
  "type": "object",
  "required": [
    "project_id",
    "goal",
    "research_theme",
    "disease_scope",
    "organisms",
    "priority_tissues",
    "priority_cells",
    "target_routes",
    "modalities_mvp",
    "constraints"
  ],
  "properties": {
    "project_id": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "research_theme": {"type": "string", "minLength": 1},
    "disease_scope": {
      "type": "object",
      "required": ["canonical"],
      "properties": {
        "canonical": {"type": "string", "minLength": 1},
        "related_phenotypes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "organisms": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "priority_tissues": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "priority_cells": {"type": "array", "items": {"type": "string"}},
    "target_routes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "modalities_mvp": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "optional": {"type": "array", "items": {"type": "string"}}
      }
    },
    "constraints": {"type": "object"}
  }
}
